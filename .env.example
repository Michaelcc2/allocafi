# AllocaFi local/Render environment example.
# Do not commit a real .env file with live keys.

NODE_ENV=development
PORT=8765
ALLOCAFI_PUBLIC_ORIGIN=http://127.0.0.1:8765
ALLOCAFI_RATE_LIMIT=120

# Solana/PYUSD balance reads. Prefer one production RPC URL.
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=replace_with_helius_key
# HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=replace_with_helius_key
# ALCHEMY_SOLANA_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/replace_with_alchemy_key

# AI insights. Leave blank to use local AI rules only.
OPENAI_API_KEY=replace_with_openai_key
OPENAI_MODEL=gpt-4.1

# WalletConnect/Reown. Used for WalletConnect-compatible wallets.
WALLETCONNECT_PROJECT_ID=replace_with_reown_project_id

# Later: Supabase Auth/database.
SUPABASE_URL=replace_with_supabase_url
SUPABASE_ANON_KEY=replace_with_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key
DATABASE_URL=replace_with_database_url

# Later: Plaid sandbox/live bank connection.
PLAID_CLIENT_ID=replace_with_plaid_client_id
PLAID_SECRET=replace_with_plaid_secret
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US

# Later: paid plans.
STRIPE_SECRET_KEY=replace_with_stripe_secret_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret
